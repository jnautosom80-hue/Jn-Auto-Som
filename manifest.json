{
  "name": "JN Auto Som Player",
  "short_name": "JN Som",
  "description": "Player de vídeos automotivo JN Auto Som",
  "start_url": "/index.html",
  "display": "fullscreen",
  "background_color": "#0a0a0a",
  "theme_color": "#0a0a0a",
  "orientation": "landscape",
  "categories": ["video", "entertainment"],
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "android": {
    "permissions": [
      "android.permission.INTERNET",
      "android.permission.READ_EXTERNAL_STORAGE"
    ],
    "features": [
      "android.hardware.screen.landscape"
    ]
  }
}
